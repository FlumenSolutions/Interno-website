# Database (Vercel Postgres / Neon)
# En Vercel: Storage > Create Database > Postgres. Luego copia "Prisma" > DATABASE_URL.
# Formato: postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgres://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Email (Resend)
RESEND_API_KEY="your_resend_api_key_here"
RESEND_FROM_EMAIL="contacto@flumensolutions.com"
RESEND_TO_EMAIL="info@flumensolutions.com"

# Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Retargeting pixels (opcionales — déjalos vacíos si aún no usas pauta)
# Meta Pixel: Business Manager > Eventos > Orígenes de datos > ID del píxel (solo dígitos)
NEXT_PUBLIC_META_PIXEL_ID=""
# LinkedIn Insight Tag: Campaign Manager > Activos de la cuenta > Insight Tag > Partner ID (solo dígitos)
NEXT_PUBLIC_LINKEDIN_ID=""

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER="+573001234567"

# Site URL
NEXT_PUBLIC_SITE_URL="https://flumensolutions.com"
